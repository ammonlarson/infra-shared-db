{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run pre-commit hook",
      "type": "node-terminal",
      "request": "launch",
      "preLaunchTask": "Run pre-commit hook",
      "command": "true",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Open DB tunnel",
      "type": "node-terminal",
      "request": "launch",
      "command": "scripts/db-tunnel.sh",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Start bastion session",
      "type": "node-terminal",
      "request": "launch",
      "command": "aws ssm start-session --target $(terraform output -raw bastion_instance_id) --region eu-north-1",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
