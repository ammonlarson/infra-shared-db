{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run pre-commit hook",
      "type": "shell",
      "command": "./.githooks/pre-commit",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
