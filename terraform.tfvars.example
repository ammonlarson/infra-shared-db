# Copy this file to `terraform.tfvars` only if you need to override the
# defaults below. For the standard workflow you do NOT need a tfvars file at
# all — the defaults already match the documented SSM tunnel.
#
# RDS is private (publicly_accessible = false). The postgresql provider talks
# to the local end of the SSM port-forward opened by scripts/db-tunnel.sh, not
# to the RDS endpoint. The defaults are 127.0.0.1:5432, which is what the tunnel
# maps by default — see the "Operator DB/Terraform access" section in README.md.
#
# Override these only if you forward RDS to a different local port (e.g. because
# 5432 is taken by a local Postgres):
#
#   scripts/db-tunnel.sh 15432
#   terraform plan -var='postgres_port=15432'   # or persist it here
#
# `terraform.tfvars` stays gitignored (`*.tfvars`); this `.example` is the
# committed template.

# postgres_host = "127.0.0.1"
# postgres_port = 5432
